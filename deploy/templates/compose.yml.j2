services:
  {{ aula_service_name }}:
    build: .
    restart: unless-stopped
    env_file:
      - .env
    environment:
      AULA_TOKEN_CACHE_PATH: /data/.aula_tokens.json
      AULA_SCAN_STATE_PATH: /data/.aula_scan_state.json
      AULA_RAW_CAPTURE_DIR: /data/.aula_raw
    ports:
      - "{{ aula_bind_address }}:{{ aula_port }}:8767"
    volumes:
      - {{ aula_data_dir }}:/data
    command:
      - aula-project
      - summary-server
      - --host
      - "0.0.0.0"
      - --port
      - "8767"
      - --thread-limit
      - "{{ aula_thread_limit }}"
      - --limit
      - "{{ aula_summary_limit }}"

{% if aula_notify_enabled | bool %}
  aula-notify:
    build: .
    restart: unless-stopped
    env_file:
      - .env
    environment:
      AULA_TOKEN_CACHE_PATH: /data/.aula_tokens.json
      AULA_SCAN_STATE_PATH: /data/.aula_scan_state.json
      AULA_RAW_CAPTURE_DIR: /data/.aula_raw
    volumes:
      - {{ aula_data_dir }}:/data
    command:
      - /bin/sh
      - -c
      - >-
        while true; do
          aula-project notify-new --thread-limit {{ aula_notify_thread_limit }};
          sleep {{ aula_notify_interval_minutes * 60 }};
        done
{% endif %}
